class Solution:
    def checkStrings(self, s1: str, s2: str) -> bool:

        d = {}
        for i in range(0, len(s1), 2):
            d[s1[i]] = d.get(s1[i], 0) + 1

        for i in range(0, len(s2), 2):
            if (d.get(s2[i]) and d[s2[i]] > 0):
                d[s2[i]] -= 1
            else:
                return False

        for i in range(1, len(s1), 2):
            d[s1[i]] = d.get(s1[i], 0) + 1

        for i in range(1, len(s2), 2):
            if (d.get(s2[i]) and d[s2[i]] > 0):
                d[s2[i]] -= 1
            else:
                return False

        return True
